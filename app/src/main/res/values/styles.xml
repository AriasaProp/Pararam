<resources>
    <style name="BaseTheme" parent="android:Theme.Material.Light">
        <item name="android:textColorPrimary">#FF0F0F0F</item>
        <item name="android:colorPrimary">#FFFFFFFF</item>
        <item name="android:colorPrimaryDark">#FF333333</item>
        <item name="android:colorAccent">#FF259024</item>
        <item name="android:textColor">#FF050505</item>
